/dts-v1/;

#include <nxp/imxrt/nxp_rt1060.dtsi>
#include "google_gotham-pinctrl.dtsi"

#include <zephyr/dt-bindings/adc/adc.h>
#include <zephyr/dt-bindings/input/input-event-codes.h>

/ {
	model = "Google Stadia Controller (gotham)";
	compatible = "google,gotham";

	chosen {
		zephyr,itcm = &itcm;
		zephyr,dtcm = &dtcm;
		zephyr,console = &lpuart1;
		zephyr,shell-uart = &lpuart1;
		zephyr,flash-controller = &zd25lq128;
		zephyr,bt-hci = &bt_hci;
	};

	aliases {
		led0 = &lp5562;
		sw0 = &stadia_button;
		watchdog0 = &wdog0;
		sdhc0 = &usdhc1;
		rtc = &counter_rtc;
	};

	gamepad-digital {
		compatible = "gpio-keys";

		stadia_button: button-stadia {
			label = "Stadia";
			gpios = <&gpio2 11 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_MODE>;
		};

		button-options {
			label = "Options";
			gpios = <&gpio2 12 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_SELECT>;
		};

		button-menu {
			label = "Menu";
			gpios = <&gpio2 13 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_START>;
		};

		button-assistant {
			label = "Assistant";
			gpios = <&gpio2 14 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_TASK>;
		};

		button-capture {
			label = "Capture";
			gpios = <&gpio2 15 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_EXTRA>;
		};

		button-a {
			label = "A";
			gpios = <&gpio2 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_SOUTH>;
		};

		button-b {
			label = "B";
			gpios = <&gpio2 1 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_EAST>;
		};

		button-x {
			label = "X";
			gpios = <&gpio2 2 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_WEST>;
		};

		button-y {
			label = "Y";
			gpios = <&gpio2 3 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_NORTH>;
		};

		dpad-up {
			label = "Up";
			gpios = <&gpio3 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_DPAD_UP>;
		};

		dpad-down {
			label = "Down";
			gpios = <&gpio3 1 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_DPAD_DOWN>;
		};

		dpad-left {
			label = "Left";
			gpios = <&gpio3 2 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_DPAD_LEFT>;
		};

		dpad-right {
			label = "Right";
			gpios = <&gpio3 3 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_DPAD_RIGHT>;
		};

		button-l1 {
			label = "L1";
			gpios = <&gpio4 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_TL>;
		};

		button-r1 {
			label = "R1";
			gpios = <&gpio4 1 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_TR>;
		};

		button-l3 {
			label = "L3";
			gpios = <&gpio1 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_THUMBL>;
		};

		button-r3 {
			label = "R3";
			gpios = <&gpio1 2 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			zephyr,code = <INPUT_BTN_THUMBR>;
		};
	};

	gamepad-analog {
		compatible = "analog-axis";
		poll-period-ms = <15>;

		axis-r3-x {
			io-channels = <&adc1 9>;
			in-deadzone = <200>;
			in-min = <0>;
			in-max = <3300>;
			zephyr,axis = <INPUT_ABS_RX>;
		};

		axis-r3-y {
			io-channels = <&adc1 10>;
			in-deadzone = <200>;
			in-min = <0>;
			in-max = <3300>;
			zephyr,axis = <INPUT_ABS_RY>;
		};

		axis-l3-x {
			io-channels = <&adc1 11>;
			in-deadzone = <200>;
			in-min = <0>;
			in-max = <3300>;
			zephyr,axis = <INPUT_ABS_X>;
		};

		axis-l3-y {
			io-channels = <&adc1 12>;
			in-deadzone = <200>;
			in-min = <0>;
			in-max = <3300>;
			zephyr,axis = <INPUT_ABS_Y>;
		};

		axis-l2 {
			io-channels = <&adc1 13>;
			in-min = <0>;
			in-max = <3300>;
			zephyr,axis = <INPUT_ABS_BRAKE>;
		};

		axis-r2 {
			io-channels = <&adc1 8>;
			in-min = <0>;
			in-max = <3300>;
			zephyr,axis = <INPUT_ABS_GAS>;
		};
	};

	hall-effect-pwr {
		compatible = "regulator-fixed";
		regulator-name = "hall-effect-pwr";
		enable-gpios = <&gpio2 10 GPIO_ACTIVE_LOW>;
		regulator-boot-on;
	};
};

&flexram {
	/*
	 * Reset FlexRAM to default layout (copied from fuses) because Google's
	 * bootloader sets a different layout and IOMUXC_GPR registers aren't
	 * reset when resetting into SDP from there.
	 */
	flexram,bank-spec = <FLEXRAM_OCRAM>,
			    <FLEXRAM_OCRAM>,
			    <FLEXRAM_OCRAM>,
			    <FLEXRAM_OCRAM>,
			    <FLEXRAM_DTCM>,
			    <FLEXRAM_DTCM>,
			    <FLEXRAM_ITCM>,
			    <FLEXRAM_ITCM>,
			    <FLEXRAM_ITCM>,
			    <FLEXRAM_ITCM>,
			    <FLEXRAM_DTCM>,
			    <FLEXRAM_DTCM>,
			    <FLEXRAM_OCRAM>,
			    <FLEXRAM_OCRAM>,
			    <FLEXRAM_OCRAM>,
			    <FLEXRAM_OCRAM>;
};

&flexspi {
	reg = <0x402a8000 0x4000>, <0x60000000 DT_SIZE_M(16)>;
	pinctrl-0 = <&pinmux_flexspi>;
	pinctrl-names = "default";
	ahb-prefetch;
	ahb-read-addr-opt;
	rx-clock-source = <1>;

	status = "okay";

	zd25lq128: zd25lq128@0 {
		compatible = "nxp,imx-flexspi-nor";
		reg = <0>;
		ranges = <0x0 0x60000000 DT_SIZE_M(16)>;
		size = <DT_SIZE_M(16 * 8)>;
		#address-cells = <1>;
		#size-cells = <1>;

		spi-max-frequency = <DT_FREQ_M(133)>;
		jedec-id = [c8 60 18];
		erase-block-size = <DT_SIZE_K(4)>;
		write-block-size = <1>;

		status = "okay";

		partitions {
			compatible = "fixed-partitions";
			ranges;
			#address-cells = <1>;
			#size-cells = <1>;

			/* Flash Configuration Block */
			partition@0 {
				label = "fcb";
				reg = <0x000000 DT_SIZE_K(4)>;
			};

			/* Image Vector Table */
			partition@1000 {
				label = "ivt";
				reg = <0x001000 DT_SIZE_K(4)>;
			};

			/* Encrypted JSON crash logs */
			partition@6000 {
				label = "crash";
				reg = <0x006000 DT_SIZE_K(136)>;
			};

			/* Encrypted Key/Value Store for user configuration */
			kv_user_partition: partition@28000 {
				label = "kv-user";
				reg = <0x028000 DT_SIZE_K(32)>;
			};

			/* Encrypted Key/Value Store for immutable device metadata */
			kv_factory_partition: partition@38000 {
				label = "kv-factory";
				reg = <0x038000 DT_SIZE_K(16)>;
			};

			partition@3c000 {
				label = "kv-boot";
				reg = <0x03c000 DT_SIZE_K(16)>;
			};

			slot_a_partition: partition@40000 {
				label = "slot-a";
				reg = <0x040000 (DT_SIZE_M(8) - DT_SIZE_K(256))>;
			};

			partition@800000 {
				label = "boot-a";
				reg = <0x800000 DT_SIZE_K(128)>;
			};

			partition@820000 {
				label = "boot-b";
				reg = <0x820000 DT_SIZE_K(128)>;
			};

			slot_b_partition: partition@840000 {
				label = "slot-b";
				reg = <0x840000 (DT_SIZE_M(8) - DT_SIZE_K(256))>;
			};
		};
	};
};

&lpi2c1 {
	pinctrl-0 = <&pinmux_lpi2c1>;
	pinctrl-names = "default";

	// TODO: devices

	status = "okay";
};

&lpi2c2 {
	pinctrl-0 = <&pinmux_lpi2c2>;
	pinctrl-names = "default";

	status = "okay";

	lp5562: leds@30 {
		compatible = "ti,lp5562";
		reg = <0x30>;

		status = "okay";
	};
};

&lpuart1 {
	pinctrl-0 = <&pinmux_lpuart1>;
	pinctrl-names = "default";
	current-speed = <115200>;

	status = "okay";
};

&lpuart3 {
	pinctrl-0 = <&pinmux_lpuart3>;
	pinctrl-1 = <&pinmux_lpuart3_flow_control>;
	pinctrl-names = "default", "flowcontrol";
	current-speed = <115200>;
	hw-flow-control;

	status = "okay";

	bt_hci: bluetooth {
		compatible = "zephyr,bt-hci-uart";

		status = "okay";

		bcm43458f_bt {
			compatible = "infineon,bt-hci-uart";
			status = "okay";

			bt-reg-on-gpios = <&gpio3 20 GPIO_ACTIVE_HIGH>;
			// TODO: bt-dev-wake-gpios?
			fw-download-speed = <4000000>;
			hci-operation-speed = <4000000>;
		};
	};
};

&adc1 {
	pinctrl-0 = <&pinmux_joysticks>;
	pinctrl-names = "default";
	#address-cells = <1>;
	#size-cells = <0>;

	status = "okay";

	r3_x: channel@9 {
		reg = <9>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	r3_y: channel@a {
		reg = <10>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	l3_x: channel@b {
		reg = <11>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	l3_y: channel@c {
		reg = <12>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	l2: channel@d {
		reg = <13>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};

	r2: channel@8 {
		reg = <8>;
		zephyr,gain = "ADC_GAIN_1";
		zephyr,reference = "ADC_REF_INTERNAL";
		zephyr,acquisition-time = <ADC_ACQ_TIME_DEFAULT>;
		zephyr,resolution = <12>;
	};
};

zephyr_udc0: &usb1 {
	phy-handle = <&usbphy1>;

	status = "okay";
};

zephyr_uhc0: &usbh1 {
	phy-handle = <&usbphy1>;

	status = "okay";
};

&usbphy1 {
	tx-d-cal = <6>;
	tx-cal-45-dp-ohms = <3>;
	tx-cal-45-dm-ohms = <3>;

	status = "okay";
};

&usdhc1 {
	pinctrl-0 = <&pinmux_usdhc1>;
	pinctrl-names = "default";

	/* Broadcom backplane writes fail above ~100MHz or with DDR. */
	max-bus-freq = <DT_FREQ_M(50)>;

	status = "okay";

	bcm43458f_wifi {
		compatible = "infineon,airoc-wifi";
		wifi-reg-on-gpios = <&gpio3 21 GPIO_ACTIVE_HIGH>;
		wifi-host-wake-gpios = <&gpio3 23 GPIO_ACTIVE_HIGH>;

		status = "okay";
	};
};

&edma0 {
	status = "okay";
};

&wdog0 {
	status = "okay";
};

// TODO
#if 0
&sai1 {
	pinctrl-0 = <&pinmux_sai1>;
	pinctrl-names = "default";

	status = "okay";
};
#endif

&gpt_hw_timer {
	status = "okay";
};

&systick {
	status = "okay";
};

&iomuxcgpr {
	status = "okay";
};

&pit0 {
	status = "okay";
};

&counter_rtc {
	status = "okay";
};
